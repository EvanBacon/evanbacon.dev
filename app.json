{
  "expo": {
    "name": "Bacon Blog",
    "slug": "bacon",
    "scheme": "bacon",
    "platforms": [
      "web"
    ],
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "server"
    },
    "android": {
      "package": "evanbacon.dev"
    },
    "experiments": {
      "tsconfigPaths": true,
      "typedRoutes": true
    },
    "ios": {
      "bundleIdentifier": "evanbacon.dev",
      "supportsTablet": false,
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "",
          "headOrigin": "https://evanbacon.dev",
          "asyncRoutes": true,
          "unstable_useServerDataLoaders": true,
          "redirects": [
            {
              "source": "/blog/expo-2024",
              "destination": "/blog/expo-apps",
              "permanent": true
            },
            {
              "source": "/expo/showcase",
              "destination": "/blog/expo-apps",
              "permanent": true
            }
          ]
        }
      ],
      "expo-quick-actions",
      "expo-video",
      "expo-web-browser",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "64b8e4a4-baf5-4160-90fe-ecfa7a32e6b8"
      }
    }
  }
}
